{
  "mcpServers": {
    "tilth": {
      "command": "tilth",
      "args": ["--mcp"]
    },
    "figma": {
      "type": "http",
      "url": "https://mcp.figma.com/mcp"
    },
    "backlog": {
      "command": "npx",
      "args": ["-y", "@nulab/backlog-mcp-server"],
      "env": {
        "BACKLOG_DOMAIN": "dipro-vn.backlog.com",
        "BACKLOG_API_KEY": ""
      }
    }
  }
}
