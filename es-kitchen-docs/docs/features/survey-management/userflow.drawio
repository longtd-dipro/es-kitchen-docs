<mxfile host="app.diagrams.net" version="21.0.0">
  <diagram name="Survey Management - User Flow" id="survey-userflow">
    <mxGraphModel dx="1200" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="1827" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- =================== SWIMLANES =================== -->

        <mxCell id="3" value="Admin (E03 — System Admin Web)" style="swimlane;fontStyle=1;align=center;startSize=30;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="20" y="20" width="280" height="1720" as="geometry"/>
        </mxCell>

        <mxCell id="4" value="System / API (es-kitchen-api)" style="swimlane;fontStyle=1;align=center;startSize=30;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="300" y="20" width="280" height="1720" as="geometry"/>
        </mxCell>

        <mxCell id="5" value="End User (E01 — Payment App)" style="swimlane;fontStyle=1;align=center;startSize=30;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="580" y="20" width="280" height="1720" as="geometry"/>
        </mxCell>

        <!-- =================== ADMIN NODES =================== -->

        <mxCell id="10" value="Start" style="ellipse;whiteSpace=wrap;html=1;fillColor=#1e4d78;fontColor=#ffffff;strokeColor=#1e4d78;fontStyle=1;" vertex="1" parent="3">
          <mxGeometry x="100" y="50" width="80" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="11" value="Open Survey Management" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="3">
          <mxGeometry x="40" y="120" width="200" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="12" value="Click &quot;Create Distribution&quot;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="3">
          <mxGeometry x="40" y="190" width="200" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="13" value="Select Survey Type&#xa;(3 fixed types)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="3">
          <mxGeometry x="40" y="260" width="200" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="15" value="Send&#xa;Immediately?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontStyle=1;" vertex="1" parent="3">
          <mxGeometry x="60" y="330" width="160" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="16" value="Set Date &amp; Time" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="3">
          <mxGeometry x="40" y="430" width="200" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="17" value="Select Target Audience&#xa;(Corporations / Individuals)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="3">
          <mxGeometry x="40" y="510" width="200" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="18" value="Target =&#xa;Corporations?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontStyle=1;" vertex="1" parent="3">
          <mxGeometry x="60" y="595" width="160" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="19" value="Select Companies&#xa;(multi-select)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="3">
          <mxGeometry x="40" y="695" width="200" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="20" value="Click Confirm" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1e4d78;fontColor=#ffffff;strokeColor=#1e4d78;fontStyle=1;" vertex="1" parent="3">
          <mxGeometry x="40" y="775" width="200" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="29" value="⏳ Survey distributed&#xa;Admin waits for responses..." style="text;html=1;strokeColor=#cccccc;fillColor=#f5f5f5;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontStyle=2;fontSize=10;fontColor=#666666;" vertex="1" parent="3">
          <mxGeometry x="30" y="870" width="220" height="460" as="geometry"/>
        </mxCell>

        <mxCell id="30" value="View Distribution History" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="3">
          <mxGeometry x="40" y="1380" width="200" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="31" value="Click on Distribution Record" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="3">
          <mxGeometry x="40" y="1450" width="200" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="32" value="View Response Analysis&#xa;(Charts + Numerical Summary)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="3">
          <mxGeometry x="40" y="1520" width="200" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="33" value="End" style="ellipse;whiteSpace=wrap;html=1;fillColor=#1e4d78;fontColor=#ffffff;strokeColor=#1e4d78;fontStyle=1;" vertex="1" parent="3">
          <mxGeometry x="100" y="1610" width="80" height="40" as="geometry"/>
        </mxCell>

        <!-- =================== SYSTEM NODES =================== -->

        <mxCell id="40" value="Create Distribution Record&#xa;(status: Scheduled / Sent)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="4">
          <mxGeometry x="40" y="775" width="200" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="41" value="Scheduled?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontStyle=1;" vertex="1" parent="4">
          <mxGeometry x="60" y="860" width="160" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="42" value="Wait until scheduled time&#xa;(Cron Job)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="4">
          <mxGeometry x="40" y="960" width="200" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="43" value="Send Push Notification&#xa;(Firebase) to target users" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="4">
          <mxGeometry x="40" y="1045" width="200" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="44" value="Save Response to DB" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="4">
          <mxGeometry x="40" y="1265" width="200" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="45" value="Auto Aggregate Responses&#xa;(per question / per survey)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="4">
          <mxGeometry x="40" y="1340" width="200" height="50" as="geometry"/>
        </mxCell>

        <!-- =================== USER NODES =================== -->

        <mxCell id="50" value="Receive Push Notification&#xa;&quot;You have a new survey&quot;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="5">
          <mxGeometry x="40" y="1045" width="200" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="51" value="Tap → Open Survey Form" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="5">
          <mxGeometry x="40" y="1125" width="200" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="52" value="Answer Questions&#xa;(Rating / Choice / Free Text)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="5">
          <mxGeometry x="40" y="1195" width="200" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="53" value="Tap Submit" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d6b656;strokeColor=#d6b656;fontColor=#ffffff;fontStyle=1;" vertex="1" parent="5">
          <mxGeometry x="40" y="1275" width="200" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="54" value="Show Thank You Screen&#xa;(survey locked — no re-submit)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="5">
          <mxGeometry x="40" y="1345" width="200" height="50" as="geometry"/>
        </mxCell>

        <!-- =================== EDGES =================== -->

        <!-- Admin: Start → Confirm -->
        <mxCell id="100" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="10" target="11" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="101" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="11" target="12" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="102" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="12" target="13" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="103" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="13" target="15" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- Decision: Immediate? Yes → target (bypass date/time) -->
        <mxCell id="104" value="Yes" style="edgeStyle=orthogonalEdgeStyle;exitX=1;exitY=0.5;exitDx=0;exitDy=0;" edge="1" source="15" target="17" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <!-- No → set date/time -->
        <mxCell id="105" value="No (Schedule)" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="15" target="16" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="106" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="16" target="17" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <mxCell id="107" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="17" target="18" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- Decision: Corporations? Yes → select companies -->
        <mxCell id="108" value="Yes" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="18" target="19" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <!-- No → confirm directly -->
        <mxCell id="109" value="No (Individuals)" style="edgeStyle=orthogonalEdgeStyle;exitX=1;exitY=0.5;exitDx=0;exitDy=0;" edge="1" source="18" target="20" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="110" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="19" target="20" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- Admin Confirm → System Create Distribution -->
        <mxCell id="111" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#1e4d78;strokeWidth=2;" edge="1" source="20" target="40" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- System: Create → Decision Scheduled? -->
        <mxCell id="112" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="40" target="41" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- System: Scheduled? Yes → wait -->
        <mxCell id="113" value="Yes" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="41" target="42" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <!-- System: No → send immediately -->
        <mxCell id="114" value="No (Immediate)" style="edgeStyle=orthogonalEdgeStyle;exitX=1;exitY=0.5;exitDx=0;exitDy=0;" edge="1" source="41" target="43" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="115" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="42" target="43" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- System Send Push → User Receive (dashed: async event) -->
        <mxCell id="116" value="Push via Firebase" style="edgeStyle=orthogonalEdgeStyle;dashed=1;strokeColor=#d79b00;strokeWidth=2;" edge="1" source="43" target="50" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- User flow -->
        <mxCell id="117" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="50" target="51" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="118" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="51" target="52" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="119" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="52" target="53" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="120" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="53" target="54" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- User Submit → System Save (dashed: API call) -->
        <mxCell id="121" value="POST /survey-responses" style="edgeStyle=orthogonalEdgeStyle;dashed=1;strokeColor=#82b366;strokeWidth=2;" edge="1" source="53" target="44" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- System: Save → Aggregate -->
        <mxCell id="122" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="44" target="45" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- System Aggregate → Admin History (dashed: data ready) -->
        <mxCell id="123" value="Data available" style="edgeStyle=orthogonalEdgeStyle;dashed=1;strokeColor=#6c8ebf;strokeWidth=2;" edge="1" source="45" target="30" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- Admin: History → Analysis → End -->
        <mxCell id="124" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="30" target="31" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="125" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="31" target="32" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="126" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="32" target="33" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
